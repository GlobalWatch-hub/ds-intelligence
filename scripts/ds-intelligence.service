[Unit]
Description=DS Intelligence API (FastAPI / uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ds-engine/backend
EnvironmentFile=/home/ubuntu/ds-engine/backend/.env
ExecStart=/home/ubuntu/ds-engine/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8005 --workers 1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
